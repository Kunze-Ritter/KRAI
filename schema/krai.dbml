  id uuid [pk]
  correlation_id varchar [not null]
  stage_name varchar [not null]
  error_type varchar [not null]
  error_message text [not null]
  error_details json
  document_id uuid
  file_path text
  metadata json
  severity varchar
  is_resolved boolean
  resolved_by varchar
  resolved_at timestamptz
  resolution_notes text
  created_at timestamptz
  updated_at timestamptz
  error_id varchar [not null]
  error_category varchar
  stack_trace text
  context json
  retry_count int [not null]
  max_retries int [not null]
  status varchar [not null]
  is_transient boolean [not null]
  next_retry_at timestamp
}

Table krai_system.processing_queue {
  id uuid [pk]
  document_id uuid
  chunk_id uuid
  image_id uuid
  video_id uuid
  task_type varchar [not null]
  priority int
  status varchar
  scheduled_at timestamptz
  started_at timestamptz
  completed_at timestamptz
  error_message text
  retry_count int
  max_retries int
  created_at timestamptz
  stage varchar [not null]
  payload json
  updated_at timestamptz
}

Table krai_system.prompt_templates {
  id int [pk]
  title varchar [not null]
  description varchar
  prompt_text text [not null]
  category varchar [not null]
  icon varchar
  sort_order int [not null]
  is_active boolean [not null]
  created_at timestamptz
  updated_at timestamptz
}

Table krai_system.retry_policies {
  Note: 'Configurable retry policies per service/stage'
  id uuid [pk]
  policy_name varchar [not null]
  service_name varchar [not null]
  stage_name varchar
  max_retries int [not null]
  base_delay_seconds decimal [not null]
  max_delay_seconds decimal [not null]
  exponential_base decimal [not null]
  jitter_enabled boolean [not null]
  circuit_breaker_enabled boolean [not null]
  circuit_breaker_threshold int [not null]
  circuit_breaker_timeout_seconds int [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table krai_system.stage_completion_markers {
  Note: 'Tracks stage completion with data hashing for idempotency checks'
  document_id uuid [pk]
  stage_name varchar [pk]
  completed_at timestamptz
  data_hash varchar
  metadata json
}

Table krai_system.stage_metrics {
  Note: 'Real-time stage processing metrics for each document'
  id uuid [pk]
  document_id uuid [not null]
  stage_name varchar [not null]
  processing_time decimal [not null]
  success boolean [not null]
  error_message text
  correlation_id varchar
  created_at timestamp [not null]
}

Table krai_system.stage_tracking {
  Note: 'Tracks pipeline stage execution per document'
  id uuid [pk]
  document_id uuid [not null]
  stage_number int [not null]
  stage_name varchar [not null]
  status varchar [not null]
  started_at timestamptz
  completed_at timestamptz
  error_message text
  metadata json
  created_at timestamptz
  updated_at timestamptz
}

Table krai_system.system_metrics {
  id uuid [pk]
  metric_name varchar [not null]
  metric_value decimal
  metric_unit varchar
  metric_category varchar
  collection_timestamp timestamptz
  server_instance varchar
  additional_context json
}

TableGroup krai_users {
  krai_users.chat_messages
  krai_users.chat_sessions
  krai_users.token_blacklist
  krai_users.user_sessions
  krai_users.users
}

Table krai_users.chat_messages {
  id bigint [pk]
  session_id uuid [not null]
  role varchar [not null]
  content text [not null]
  created_at timestamptz
}

Table krai_users.chat_sessions {
  id uuid [pk]
  user_id uuid
  session_key varchar [not null]
  title varchar
  created_at timestamptz
  updated_at timestamptz
  last_active timestamptz
}

Table krai_users.token_blacklist {
  id uuid [pk]
  jti varchar [not null]
  user_id uuid [not null]
  token_type varchar [not null]
  expires_at timestamptz [not null]
  blacklisted_at timestamptz [not null]
  reason varchar
}

Table krai_users.user_sessions {
  id uuid [pk]
  user_id uuid [not null]
  session_token varchar [not null]
  expires_at timestamptz [not null]
  created_at timestamptz
}

Table krai_users.users {
  id uuid [pk]
  preferred_manufacturer_id uuid
  username varchar [not null]
  email varchar [not null]
  role varchar
  created_at timestamptz
  password_hash varchar
  first_name varchar
  last_name varchar
  is_active boolean
  last_login timestamptz
  status varchar
  is_verified boolean
  login_count int
  failed_login_attempts int
  updated_at timestamptz
  locked_until timestamptz
  permissions json
}

TableGroup public {
  public.vw_device_lifecycle
  public.vw_part_lifetimes
  public.vw_predictions
}

Table public.vw_device_lifecycle {
  id uuid
  device_serial_hash varchar
  product_id uuid
  counter_total bigint
  counter_color bigint
  counter_bw bigint
  measured_at timestamptz
  toner_levels json
  maintenance_events json
  metadata json
  ingested_at timestamptz
}

Table public.vw_part_lifetimes {
  id uuid
  manufacturer_id uuid
  product_id uuid
  part_category varchar
  part_number varchar
  nominal_lifetime_pages int
  color_channel varchar
  source varchar
  metadata json
  ingested_at timestamptz
}

Table public.vw_predictions {
  id uuid
  device_serial_hash varchar
  prediction_type varchar
  target_part_category varchar
  predicted_event_date date
  predicted_remaining_pages int
  risk_score double
  confidence double
  model_name varchar
  model_version varchar
  mlflow_run_id varchar
  created_at timestamptz
  ground_truth_event_date date
  ground_truth_set_at timestamptz
}

